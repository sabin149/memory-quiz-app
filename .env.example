# Appwrite configuration (see https://cloud.appwrite.io -> your project -> Settings)
# EXPO_PUBLIC_ variables are embedded in the app bundle; do not put server keys here.
EXPO_PUBLIC_APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
EXPO_PUBLIC_APPWRITE_PROJECT_ID=your-project-id

# Optional: Appwrite Function id for LLM-based quiz generation
# (functions/generate-quiz). Leave unset to use on-device generation.
# EXPO_PUBLIC_APPWRITE_QUIZ_FUNCTION_ID=

# Server API key, ONLY used by scripts/setup-appwrite.mjs (never by the app).
# Scopes: databases.write, teams.write, users.read. Prefer a short-lived key.
# NEVER prefix this with EXPO_PUBLIC_ (that would embed it in the app bundle),
# and never commit .env.
# APPWRITE_API_KEY=
